#!/bin/bash
# DockPanel pre-commit hook: scan for infrastructure leaks
# This catches real IPs, hostnames, passwords, and tokens before they enter the repo.

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'
FOUND=0

echo "=== Pre-commit: infrastructure leak scan ==="

# Get staged files only
STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(rs|ts|tsx|sql|toml|sh|md|json|yml|yaml|env)$')

if [ -z "$STAGED" ]; then
  echo -e "${GREEN}No scannable files staged.${NC}"
  exit 0
fi

# Scan staged content (not working directory) for secrets
DIFF=$(git diff --cached -- $STAGED)

# Real server IPs
if echo "$DIFF" | grep -qE '95\.179\.144\.140|45\.32\.232\.132|136\.244\.102\.195|78\.141\.211\.78'; then
  echo -e "${RED}BLOCKED: Real server IP found in staged changes${NC}"
  echo "$DIFF" | grep -nE '95\.179\.144\.140|45\.32\.232\.132|136\.244\.102\.195|78\.141\.211\.78' | head -5
  FOUND=1
fi

# Home server IP
if echo "$DIFF" | grep -qE '192\.168\.1\.186'; then
  echo -e "${RED}BLOCKED: Home server IP found in staged changes${NC}"
  FOUND=1
fi

# Internal hostnames
if echo "$DIFF" | grep -qE 'test\.dockpanel\.dev|demo\.dockpanel\.dev'; then
  # Allow in memory files and docs that reference these as examples
  REAL_HITS=$(echo "$DIFF" | grep -E 'test\.dockpanel\.dev|demo\.dockpanel\.dev' | grep -v '^[+-].*#\|^[+-].*//\|^[+-].*<!--' | grep -v 'memory/' | head -3)
  if [ -n "$REAL_HITS" ]; then
    echo -e "${RED}WARNING: Internal hostname found in staged changes${NC}"
    echo "$REAL_HITS"
    # Warning only, not blocking — these appear in docs/comments legitimately
  fi
fi

# Passwords and tokens
if echo "$DIFF" | grep -qiE 'PTHEsBzagJBWE8NuJjA|dockpanel2026|github_pat_'; then
  echo -e "${RED}BLOCKED: Password or token found in staged changes${NC}"
  echo "$DIFF" | grep -niE 'PTHEsBzagJBWE8NuJjA|dockpanel2026|github_pat_' | head -5
  FOUND=1
fi

# .env, .pem, .key files
ENV_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(env|pem|key)$' | grep -v '.sample')
if [ -n "$ENV_FILES" ]; then
  echo -e "${RED}BLOCKED: Sensitive file type staged: ${ENV_FILES}${NC}"
  FOUND=1
fi

if [ "$FOUND" -eq 1 ]; then
  echo -e "${RED}Commit blocked. Remove sensitive data before committing.${NC}"
  exit 1
fi

echo -e "${GREEN}Clean — no infrastructure leaks detected.${NC}"
exit 0
